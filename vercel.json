{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "installCommand": "cd backend && npm install",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/py_*.py": {
      "runtime": "@vercel/python@4.5.0",
      "includeFiles": "backend/*.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/evaluate",
      "destination": "/api/py_evaluate.py"
    },
    {
      "source": "/api/analytics/:studentId",
      "destination": "/api/py_analytics.py?studentId=:studentId"
    },
    {
      "source": "/api/leaderboard",
      "destination": "/api/py_leaderboard.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
